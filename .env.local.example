# Neon (pooled connection) for app runtime (local + Vercel)
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"

# Neon direct connection (non-pooled) for Prisma migrations
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require&connect_timeout=15"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET="<generate-a-long-random-secret>"
AUTH_GOOGLE_ID="<google-oauth-client-id>"
AUTH_GOOGLE_SECRET="<google-oauth-client-secret>"
AUTH_ALLOWED_EMAILS="jane.usoskina@gmail.com"
